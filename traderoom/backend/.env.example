# =============================================
# TRADEROOM — VARIÁVEIS DE AMBIENTE (BACKEND)
# =============================================
# Renomeie este arquivo para .env e preencha os valores

# SERVIDOR
PORT=3001
NODE_ENV=development

# BANCO DE DADOS (PostgreSQL via Supabase)
# Pegue em: supabase.com → seu projeto → Settings → Database
DATABASE_URL=postgresql://postgres:[SUA_SENHA]@db.[SEU_PROJETO].supabase.co:5432/postgres

# AUTENTICAÇÃO JWT
# Crie uma senha forte qualquer — ex: openssl rand -base64 32
JWT_SECRET=coloque_aqui_uma_chave_secreta_bem_longa_e_aleatoria
JWT_EXPIRES_IN=7d

# REDIS (para salas ativas e sessões)
# Railway gera automaticamente quando você adiciona o Redis
REDIS_URL=redis://localhost:6379

# SUPABASE (para auth)
# Pegue em: supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://[SEU_PROJETO].supabase.co
SUPABASE_ANON_KEY=sua_chave_anonima_aqui
SUPABASE_SERVICE_KEY=sua_chave_service_aqui

# AGORA.IO (áudio nas salas)
# Crie conta em: agora.io → Console → Project Management
AGORA_APP_ID=seu_app_id_aqui
AGORA_APP_CERTIFICATE=seu_certificado_aqui

# MERCADO PAGO (assinatura TraderCalc)
# Crie em: mercadopago.com.br → Credenciais
MERCADOPAGO_ACCESS_TOKEN=seu_token_aqui
MERCADOPAGO_PUBLIC_KEY=sua_chave_publica_aqui

# FRONTEND (para CORS)
FRONTEND_URL=http://localhost:3000
